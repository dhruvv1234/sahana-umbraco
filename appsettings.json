{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://azmi-dev-next-bbgx.vercel.app" ]
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "69eaf269-f07e-401c-8c3c-09812718b666",
        "UseHttps": true,
        "SanitizeTinyMce": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "DeliveryApi": {
        "Enabled": true
      },
      "Runtime": {
        "Mode": "Production"
      },
      "Security": {
        "AllowConcurrentLogins": false
      }
    },
    "Forms": {
      "FormDesign": {
        "DisableDefaultWorkflow": false,
        "MaxNumberOfColumnsInFormGroup": 12,
        "DefaultTheme": "default",
        "DefaultEmailTemplate": "Forms/Emails/Example-Template.cshtml"
      },
      "Options": {
        "IgnoreWorkFlowsOnEdit": "False",
        "ExecuteWorkflowAsync": "False",
        "AllowEditableFormSubmissions": false,
        "AppendQueryStringOnRedirectAfterFormSubmission": false,
        "CacheResolvedConditionFields": true,
        "ScheduledRecordDeletion": {
          "Enabled": false,
          "FirstRunTime": "",
          "Period": "1.00:00:00"
        }
      },
      "Security": {
        "DisallowedFileUploadExtensions": "ashx,aspx,ascx,config,cshtml,vbhtml,asmx,air,axd,swf,xml,xhtml,html,htm,svg,php",
        "EnableAntiForgeryToken": true,
        "SavePlainTextPasswords": false,
        "FormsApiKey": ""
      }
     
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  }
}